<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd" >
<hibernate-mapping package="com.entities">
	<joined-subclass name="MedicalInsurancePlan"
		extends="InsurancePlan" table="medical_insurance_plan">
		<key column="medical_insurance_plan_no" />
		<property name="copay" />
		<property name="coverageType" column="coverage_type" />
	</joined-subclass>
</hibernate-mapping>
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd" >
<hibernate-mapping package="com.entities">
	<subclass name="AccidentalInsurancePlan"
		extends="InsurancePlan" discriminator-value="AccidentalInsurancePlan">
		<property name="disabilityCoveragePercentage"
			column="disability_coverage_percentage" />
		<property name="internationalCoverage"
			column="international_coverage" />
	</subclass>
</hibernate-mapping>
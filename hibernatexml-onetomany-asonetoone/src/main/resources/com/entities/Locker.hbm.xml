<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN" "http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd" >
<hibernate-mapping package="com.entities">
	<class name="Locker" table="locker">
		<id name="lockerNo" column="locker_no">
			<generator class="identity" />
		</id>
		
		<property name="dimensions" />
		<property name="keyNo" column="key_no" />
		<property name="branchCode" column="branch_code" />
		<property name="termsAndConditions"
			column="terms_and_conditions" />
		<property name="charges" />


		<many-to-one name="account">
			<column name="account_no" unique="true" />
		</many-to-one>
	</class>
</hibernate-mapping>